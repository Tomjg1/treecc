

// Test 1: Basic arithmetic and return
fn int test_return_constant() {
    return 42
}

fn int test_basic_arithmetic() {
    int x = 10
    int y = 20
    return x + y
}

fn int test_arithmetic_precedence() {
    int x = 2
    int y = 3
    int z = 4
    return x + y * z
}

// Test 2: Basic if/else
fn int test_if_else(int x) {
    if (x > 0) {
        return 1
    }
    return 0
}

fn int test_if_else_both_branches(int x) {
    int result = 0
    if (x > 0) {
        result = 1
    } else {
        result = -1
    }
    return result
}

// Test 3: Nested ifs (your existing pattern)
fn int test_nested_if(int x, int y) {
    if (x > 0) {
        if (y > 0) {
            return 1
        }
        return 2
    }
    return 3
}

// Test 4: else if chain
fn int test_else_if(int x) {
    if (x < 0) {
        return 0
    } else if (x < 10) {
        return 1
    } else if (x < 100) {
        return 2
    } else {
        return 3
    }
}

fn int test_else_if_no_final_else(int x) {
    int result = 99
    if (x < 0) {
        result = 0
    } else if (x < 10) {
        result = 1
    } else if (x < 100) {
        result = 2
    }
    return result
}

// Test 5: While loop variants
fn int test_while_never_enters() {
    int i = 10
    while (i < 0) {
        i = i + 1
    }
    return i
}

// Failed add nodes not scheduled
fn int test_while_accumulate() {
    int i = 0
    int sum = 0
    while (i < 10) {
        sum = sum + i
        i = i + 1
    }
    return sum  // 0+1+2+...+9 = 45
}






// Test 8: Multiple returns in branches
fn int test_early_return(int x) {
    if (x < 0) {
        return 0
    }
    if (x < 10) {
        return x
    }
    if (x < 100) {
        return x + 1
    }
    return x + 2
}

// Failed some addtions are not being scheduled
// Test 9: Variable shadowing / reuse across branches
fn int test_var_reuse(int x) {
    int result = 0
    if (x > 10) {
        result = x + 1
    } else {
        result = x + 2
    }
    result = result + 1
    return result
}

// Pretty sure this passed
// Test 10: Complex condition expressions
fn int test_complex_condition(int x, int y) {
    int threshold = x + y
    if (threshold < 10) {
        return 0
    }
    return threshold
}

