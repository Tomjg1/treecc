fn int test_lots_of_branches(int z) {
    int x = 3

    int t = 5


    if (x < t + 2) {
        if (z > 0) {
            t = t + 1
        }
        t = 3 + x
        return 6
    }

    return x + t
}

fn int test_basic_while() {
    int i = 0
    while (i < 10) {
        i = i + 1
    }

    return i
}
